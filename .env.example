# Vercel 프로젝트 Settings → Environment Variables 에 입력하세요.
# 이 파일은 예시이며, 실제 키는 절대 깃에 커밋하지 마세요. (.gitignore에 .env 포함됨)

# ── Claude API (URL/텍스트 파싱용) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── 토스페이먼츠 ──
# 시크릿 키 (서버 전용 — 절대 프론트에 넣지 말 것)
# 테스트: test_sk_... / 라이브: live_sk_...
TOSS_SECRET_KEY=test_sk_...

# ── 솔라피(SOLAPI) 문자/알림톡 ──
# https://solapi.com 가입 후 발급. 미설정 시 알림만 생략되고 결제는 정상 동작.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=     # 솔라피에 사전 등록한 발신번호 (숫자만, 예: 0312000000)

# ── 사장님(어머니) 알림 수신 번호 (숫자만) ──
OWNER_PHONE_1=
OWNER_PHONE_2=
