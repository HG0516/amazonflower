# Vercel 프로젝트 Settings → Environment Variables 에 입력하세요.
# 이 파일은 예시이며, 실제 키는 절대 깃에 커밋하지 마세요. (.gitignore에 .env 포함됨)

# ── Claude API (URL/텍스트 파싱용) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── 토스페이먼츠 ──
# 시크릿 키 (서버 전용 — 절대 프론트에 넣지 말 것)
# 테스트: test_sk_... / 라이브: live_sk_...
TOSS_SECRET_KEY=test_sk_...

# ── 솔라피(SOLAPI) 문자/알림톡 ──
# https://solapi.com 가입 후 발급. 미설정 시 알림만 생략되고 결제는 정상 동작.
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=     # 솔라피에 사전 등록한 발신번호 (숫자만, 예: 0312000000)

# ── 사장님(어머니) 알림 수신 번호 (숫자만) ──
OWNER_PHONE_1=
OWNER_PHONE_2=

# ── 갤러리 직접 업로드 (관리자 /admin 페이지 → api/gallery-add.js) ──
# Supabase 프로젝트 → Project Settings → API 에서 확인.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # service_role 키 (서버 전용 — 절대 프론트/깃에 넣지 말 것)
ADMIN_PASSWORD=               # 부모님이 /admin 에서 입력할 업로드 비밀번호 (직접 정하세요)
# ※ SUPABASE_URL + anon(public) 키는 supabase-config.js 에도 넣어야 카탈로그가 사진을 읽어옵니다.
